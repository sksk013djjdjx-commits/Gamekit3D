    "m_SourceType": 1,
    "m_FunctionName": "SlerpNormals",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float dot_product = dot(n1, n2);\n\n    // If the inputs are too close, linearly interpolate and normalize.\n    // This avoids issues with acos() and sin(0).\n    // The threshold (e.g., 0.9995f) can be adjusted.\n    if (dot_product > 0.9995f)\n    {\n        result = normalize(lerp(n1, n2, t));\n        return;\n    }\n\n    // Clamp dot_product to prevent acos domain errors due to floating point inaccuracies\n    dot_product = clamp(dot_product, -1.0f, 1.0f);\n\n    float theta_0 = acos(dot_product); // Angle between N1 and N2\n    float theta = theta_0 * t;         // Angle for interpolation\n\n    float3 n3 = normalize(n2 - n1 * dot_product); // Vector orthogonal to n1, in the plane of n1 and n2\n\n    result = n1 * cos(theta) + n3 * sin(theta);\n    // Re-normalize due to potential floating point inaccuracies, though theoretically it should be unit length\n    result = normalize(result);"
}

