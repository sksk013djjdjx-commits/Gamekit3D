{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "1cf94bbc7407427db5c8de483121bd3b",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "BlurReflections (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 2108.0,
            "y": 4393.0,
            "width": 240.0,
            "height": 118.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "836ccd6eff5347caa462647ce91c86ea"
        },
        {
            "m_Id": "3b8a2d123b73446db66c66ff0adb8529"
        },
        {
            "m_Id": "58e5091af9af4f968658b06eb9e7bcab"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "BlurReflections",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "color = 0;\nfloat2 blurSize = 0.1;\nfloat2 ouv = uv.xy;\nfloat k = 1.0 / 9;\nfor(int y=0; y<3; y++) {\n    for(int x=0; x<3; x++) {\n        float2 offset = float2(x-1, y-1);\n        uv.xy = ouv + blurSize * offset;\n        uv.xy/=uv.w;\n        uv.x = 1-uv.x; // our reflection is flipped horizontally\n        float4 c = tex2D(refTexture, uv.xy); \n        color += c * k;\n    }\n}"
}

