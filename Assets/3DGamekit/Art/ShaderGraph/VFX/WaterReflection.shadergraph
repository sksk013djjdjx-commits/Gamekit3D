{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "d50e8df45379435fb96796ff2e8ce06e",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "BlurBackground (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 3055.999755859375,
            "y": 3857.999755859375,
            "width": 245.000244140625,
            "height": 142.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "bde7805ab52949339711e0b2d9d51a8b"
        },
        {
            "m_Id": "6f0b66e478e641249ff9bf605ea9d522"
        },
        {
            "m_Id": "9a929e7059bc450e907139422a0cf94f"
        },
        {
            "m_Id": "c34aaaa2a69044c2b9b6882fcc320a04"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "BlurBackground",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "color = 0;\nfloat2 blurSize = _DepthBlur * _CameraOpaqueTexture_TexelSize.xy * depth;\nfloat2 ouv = uv;\nfloat k = 1.0 / 9;\nfor(int y=0; y<3; y++) {\n    for(int x=0; x<3; x++) {\n        float2 offset = float2(x-1, y-1);\n\t\tuv.xy = ouv + blurSize * offset;\n        float4 c = tex2D(bgTexture, uv); \n        color += c * k;\n    }\n}"
}

